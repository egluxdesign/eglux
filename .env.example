# ============================================================================
# EGLUX Frontend Environment Variables
# ============================================================================
# Cara pakai:
#   1. Copy file ini: cp .env.example .env
#   2. Isi nilai untuk setiap var (jangan commit .env ke git!)
#   3. Restart Vite dev server: npm run dev
#
# ⚠️ CRITICAL: Tanpa file .env yang valid, fitur pembayaran (Midtrans) dan
#    integrasi Supabase gak akan jalan. App akan render EnvErrorPage dengan
#    instruksi yang jelas saat startup kalau ada env var yang missing.
# ============================================================================

# ── Supabase ────────────────────────────────────────────────────────────────
# Dari: Supabase Dashboard → Project Settings → API
# URL project (format: https://<project-ref>.supabase.co)
VITE_SUPABASE_URL=https://mbuwpjxpxvnsxjusrnlk.supabase.co

# Anon public key (publishable, safe untuk frontend)
# ⚠️ JANGAN pakai service_role key di frontend — itu bypass RLS!
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Im1idXdwanhweHZuc3hqdXNybmxrIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODI3NzU5MzAsImV4cCI6MjA5ODM1MTkzMH0.HbF2Sp27o4S3S4Z5iZ_YTYm9DLBaB5MtmIQNWfAF_tc

# ── Midtrans Snap (Payment) ─────────────────────────────────────────────────
# Dari: Midtrans Dashboard → Settings → Access Keys
# ⚠️ Client Key = public key (safe untuk frontend). Server Key = private (HANYA backend).

# Set ke 'true' kalau sudah production (pakai app.midtrans.com)
# Set ke 'false' atau kosong untuk sandbox (pakai app.sandbox.midtrans.com)
VITE_MIDTRANS_IS_PRODUCTION=false

# Client Key dari Midtrans dashboard
# Sandbox biasanya format: SB-Mid-client-XXXXXX
# Production biasanya format: Mid-client-XXXXXX
VITE_MIDTRANS_CLIENT_KEY=Mid-client-o4PZiN5ToqWS5RcZ

# ── (Optional) Biteship ─────────────────────────────────────────────────────
# Frontend pakai Biteship via edge function (check-biteship-rates), jadi
# API key Biteship HARUS di-set di Supabase Edge Function env vars, BUKAN di sini.
# Tapi kalau frontend butuh direct call (mis. untuk search area), set ini:
# VITE_BITESHIP_API_KEY=your-biteship-api-key

# ── App Config (Optional) ───────────────────────────────────────────────────
# Default currency display
# VITE_CURRENCY=IDR

# Default locale
# VITE_LOCALE=id-ID
